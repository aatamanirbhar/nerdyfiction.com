{
  "$ref": "#/definitions/books",
  "definitions": {
    "books": {
      "type": "object",
      "properties": {
        "slug": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "series": {
          "type": "string"
        },
        "seriesOrder": {
          "type": "number"
        },
        "author": {
          "type": "string"
        },
        "tagline": {
          "type": "string"
        },
        "description": {
          "type": "string",
          "minLength": 50,
          "maxLength": 300
        },
        "publishedDate": {
          "anyOf": [
            {
              "type": "string",
              "format": "date-time"
            },
            {
              "type": "string",
              "format": "date"
            },
            {
              "type": "integer",
              "format": "unix-time"
            }
          ]
        },
        "cover": {
          "type": "object",
          "properties": {
            "gradientFrom": {
              "type": "string"
            },
            "gradientTo": {
              "type": "string"
            },
            "accent": {
              "type": "string"
            },
            "glyph": {
              "type": "string"
            }
          },
          "required": [
            "gradientFrom",
            "gradientTo",
            "accent"
          ],
          "additionalProperties": false
        },
        "characters": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string"
              },
              "name": {
                "type": "string"
              },
              "tagline": {
                "type": "string"
              },
              "silhouetteColor": {
                "type": "string"
              }
            },
            "required": [
              "id",
              "name",
              "tagline",
              "silhouetteColor"
            ],
            "additionalProperties": false
          }
        },
        "keywords": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "chapterCount": {
          "type": "integer",
          "exclusiveMinimum": 0
        },
        "$schema": {
          "type": "string"
        }
      },
      "required": [
        "slug",
        "title",
        "author",
        "tagline",
        "description",
        "publishedDate",
        "cover",
        "characters",
        "chapterCount"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}