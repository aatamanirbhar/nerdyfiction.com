---
/**
 * AnimatedBookCard — the homepage book card.
 *
 * Hover/focus: the book tilts open; SVG character silhouettes that live INSIDE
 * the book flow outward and arrange themselves around it. Mouseout: they
 * return to the page. Click: navigate to /books/<slug> (handled via Astro view transitions).
 *
 * The GSAP timeline is built lazily on first hover so the homepage shelf stays
 * server-rendered and lightweight.
 */
import { bookHref } from '@lib/nav';
import BookCover from './BookCover.astro';
import CharacterSilhouette from './CharacterSilhouette.astro';

interface Props {
  book: {
    slug: string;
    title: string;
    series?: string;
    author: string;
    tagline: string;
    cover: { gradientFrom: string; gradientTo: string; accent: string; glyph?: string };
    characters: Array<{ id: string; name: string; silhouetteColor: string }>;
  };
}

const { book } = Astro.props;
const href = bookHref(book.slug);
// Cap to 4 characters for the flow-out animation
const flyChars = book.characters.slice(0, 4);
---

<a
  href={href}
  class="animated-book-card group relative block w-fit mx-auto outline-none focus-visible:ring-2 focus-visible:ring-ember-500 rounded-md"
  data-astro-prefetch
  aria-label={`Open ${book.title} by ${book.author}`}
>
  <!-- Stage: gives room for characters to fly out -->
  <div class="relative w-[28rem] h-[34rem] flex items-center justify-center" data-stage>
    <!-- The flying characters — start hidden behind the book -->
    <div class="absolute inset-0 pointer-events-none" data-fly-layer>
      {flyChars.map((c, i) => (
        <div
          class="absolute opacity-0"
          data-character-slot
          data-index={i}
          style={`left:50%; top:50%; transform: translate(-50%, -40%);`}
        >
          <CharacterSilhouette
            id={`${book.slug}-${c.id}`}
            pose={(['idle','tense','reaching','rising'] as const)[i % 4]}
            color={c.silhouetteColor}
            size="md"
          />
        </div>
      ))}
    </div>

    <!-- The book itself -->
    <div class="relative" data-book-wrap style="transform-style: preserve-3d;">
      <div data-book-tilt class="transition-transform duration-300 will-change-transform">
        <BookCover
          title={book.title}
          series={book.series}
          author={book.author}
          cover={book.cover}
          size="lg"
        />
      </div>
      <!-- The "opening" inner glow that bursts when characters fly out -->
      <div
        class="absolute inset-y-2 left-2 right-2 rounded-r-md opacity-0 pointer-events-none"
        data-burst
        style={`background: radial-gradient(ellipse at center, ${book.cover.accent}cc, transparent 70%); mix-blend-mode: screen;`}
      ></div>
    </div>
  </div>

  <!-- Tagline -->
  <p class="mt-4 text-center text-ink-200 italic max-w-md mx-auto opacity-90 group-hover:opacity-100 transition-opacity">
    "{book.tagline}"
  </p>
</a>

<script>
  import { gsap } from 'gsap';

  type Card = HTMLElement;

  function setupCard(card: Card) {
    const bookTilt = card.querySelector<HTMLElement>('[data-book-tilt]');
    const burst    = card.querySelector<HTMLElement>('[data-burst]');
    const layer    = card.querySelector<HTMLElement>('[data-fly-layer]');
    if (!bookTilt || !burst || !layer) return;

    const slots = Array.from(layer.querySelectorAll<HTMLElement>('[data-character-slot]'));
    if (slots.length === 0) return;

    // Arrange targets in an arc above the book
    const radius = 240;
    const targets = slots.map((_, i) => {
      const n = slots.length;
      const angle = (Math.PI * (i + 1)) / (n + 1) - Math.PI / 2; // -PI/2 → +PI/2 fan
      return {
        x: Math.cos(angle) * radius,
        y: -160 + Math.sin(angle) * 40 - Math.abs(Math.cos(angle)) * 30,
        rot: (angle * 180) / Math.PI * 0.15,
      };
    });

    // Build timeline (paused, replayed on each hover)
    const tl = gsap.timeline({ paused: true, defaults: { ease: 'power3.out' } });
    tl.to(bookTilt, { rotateY: -22, rotateX: 6, scale: 1.04, duration: 0.5 }, 0)
      .to(burst,    { opacity: 0.9, duration: 0.35 }, 0.1)
      .to(burst,    { opacity: 0.35, duration: 0.6 }, '>-0.05');

    slots.forEach((slot, i) => {
      const t = targets[i];
      tl.fromTo(slot,
        { opacity: 0, x: 0, y: 0, scale: 0.6, rotate: 0 },
        { opacity: 1, x: t.x, y: t.y, scale: 1, rotate: t.rot, duration: 0.8 },
        0.15 + i * 0.08
      );
    });

    let entered = false;
    const enter = () => { entered = true; tl.play(); };
    const leave = () => { entered = false; tl.reverse(); };

    card.addEventListener('mouseenter', enter);
    card.addEventListener('mouseleave', leave);
    card.addEventListener('focusin', enter);
    card.addEventListener('focusout', leave);
  }

  function init() {
    document.querySelectorAll<HTMLElement>('.animated-book-card').forEach(setupCard);
  }
  init();
  document.addEventListener('astro:page-load', init);
</script>
