---
import { chapterHref } from '@lib/nav';

interface Props {
  bookSlug: string;
  number: number;
  title: string;
  summary: string;
  estimatedMinutes: number;
  publishedDate: Date;
}

const { bookSlug, number, title, summary, estimatedMinutes, publishedDate } = Astro.props;
const href = chapterHref(bookSlug, number);
const dateStr = publishedDate.toLocaleDateString('en-US', {
  year: 'numeric', month: 'long', day: 'numeric',
});
---

<a
  href={href}
  data-astro-prefetch
  class="chapter-card group relative block rounded-md border border-ink-700/60 bg-ink-800/40 hover:bg-ink-800/70 hover:border-ember-500/50 p-6 transition-colors outline-none focus-visible:ring-2 focus-visible:ring-ember-500"
  style="transform-style: preserve-3d; perspective: 800px;"
  aria-label={`Read chapter ${number}: ${title}`}
>
  <!-- Page-flip layer -->
  <div class="absolute inset-y-0 left-0 w-1 bg-ember-500/0 group-hover:bg-ember-500 transition-colors rounded-l-md"></div>
  <div
    class="absolute inset-0 rounded-md pointer-events-none opacity-0 group-hover:opacity-100 transition-opacity"
    style="background: linear-gradient(110deg, transparent 0%, transparent 60%, rgba(255,107,74,0.06) 100%);"
  ></div>

  <div class="relative flex items-start justify-between gap-6">
    <div class="flex-1">
      <p class="font-mono uppercase tracking-[0.25em] text-ink-400 text-[10px]">
        Chapter {number} &middot; {estimatedMinutes} min read
      </p>
      <h3 class="font-display text-2xl text-ink-50 mt-2 leading-tight group-hover:text-ember-400 transition-colors">
        {title}
      </h3>
      <p class="mt-3 text-ink-200 leading-relaxed">
        {summary}
      </p>
      <p class="mt-4 text-xs text-ink-400 italic">Published {dateStr}</p>
    </div>
    <div
      class="shrink-0 font-display text-5xl text-ember-500/30 group-hover:text-ember-500 transition-all duration-500 group-hover:translate-x-2"
      aria-hidden="true"
    >
      &rarr;
    </div>
  </div>
</a>
