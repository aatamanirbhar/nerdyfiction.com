---
/**
 * CharacterSilhouette — renders a character portrait from /public/characters/.
 *
 * Uses real images (jpegs). Pose hints map to alternate frames or subtle
 * filters; size controls render height. A soft accent glow tinted by the
 * character's silhouetteColor frames the portrait so it still feels stylized
 * against the dark stage.
 */
interface Props {
  id: string;
  pose?: 'idle' | 'tense' | 'reaching' | 'reeling' | 'seated' | 'rising';
  color?: string;
  /** small / medium / large heights */
  size?: 'sm' | 'md' | 'lg';
  class?: string;
}

const {
  pose = 'idle',
  color = '#b09f7d',
  size = 'md',
  class: className = '',
  id,
} = Astro.props;

const sizes = {
  sm: 'h-40 w-40',
  md: 'h-72 w-72',
  lg: 'h-[28rem] w-[28rem]',
};

// id may be namespaced like "ordinary-gods-robert-card" — extract trailing token
const baseId = id.split('-').slice(-1)[0] === 'card'
  ? id.split('-').slice(-2)[0]
  : id.includes('-')
    ? id.split('-').slice(-1)[0]
    : id;

// Map pose to portrait variant: tense / reaching / reeling / rising → "2" frame
const useAlt = pose === 'tense' || pose === 'reaching' || pose === 'reeling' || pose === 'rising';
const imgPath = `/characters/${baseId}${useAlt ? '2' : ''}.jpeg`;

// Pose-driven micro-transform classes
const poseClass: Record<NonNullable<Props['pose']>, string> = {
  idle:     'character-pose-idle',
  tense:    'character-pose-tense',
  reaching: 'character-pose-reaching',
  reeling:  'character-pose-reeling',
  seated:   'character-pose-seated',
  rising:   'character-pose-rising',
};
---

<div
  class={`character-portrait ${sizes[size]} ${poseClass[pose]} ${className}`}
  data-character={id}
  style={`--accent: ${color};`}
>
  <div class="character-halo" aria-hidden="true"></div>
  <div class="character-frame">
    <img
      src={imgPath}
      alt=""
      loading="lazy"
      decoding="async"
      class="character-img"
      onerror="this.style.opacity='0';"
    />
    <div class="character-vignette" aria-hidden="true"></div>
    <div class="character-scanline" aria-hidden="true"></div>
  </div>
</div>

<style>
  .character-portrait {
    position: relative;
    display: inline-block;
    pointer-events: none;
    filter: drop-shadow(0 18px 36px rgba(0, 0, 0, 0.65));
    animation: portrait-float 6s ease-in-out infinite;
    transform-origin: 50% 90%;
  }

  .character-halo {
    position: absolute;
    inset: -12% -12% -6% -12%;
    border-radius: 50%;
    background: radial-gradient(
      ellipse at 50% 45%,
      color-mix(in srgb, var(--accent) 70%, transparent) 0%,
      color-mix(in srgb, var(--accent) 25%, transparent) 35%,
      transparent 70%
    );
    filter: blur(22px);
    opacity: 0.55;
    animation: halo-pulse 3.6s ease-in-out infinite;
  }

  .character-frame {
    position: relative;
    width: 100%;
    height: 100%;
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid color-mix(in srgb, var(--accent) 35%, transparent);
    box-shadow:
      0 0 0 1px rgba(255, 255, 255, 0.04),
      inset 0 0 60px rgba(0, 0, 0, 0.55);
    background: #08070a;
  }

  .character-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 25%;
    filter: contrast(1.05) saturate(0.95) brightness(0.92);
    transition: transform 1.2s ease-out, filter 0.6s ease-out;
  }

  .character-vignette {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      radial-gradient(ellipse at 50% 35%, transparent 35%, rgba(5, 4, 2, 0.6) 100%),
      linear-gradient(180deg, transparent 60%, rgba(5, 4, 2, 0.85) 100%);
    mix-blend-mode: multiply;
  }

  .character-scanline {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: repeating-linear-gradient(
      0deg,
      rgba(255, 255, 255, 0.02) 0 1px,
      transparent 1px 3px
    );
    opacity: 0.35;
  }

  /* Pose micro-animations */
  .character-pose-idle .character-img     { transform: scale(1.02); }
  .character-pose-tense .character-img    { transform: scale(1.04) translateY(-2px); filter: contrast(1.12) saturate(1.05) brightness(0.95); }
  .character-pose-reaching .character-img { transform: scale(1.06) translateX(2%) translateY(-3px); }
  .character-pose-reeling .character-img  { transform: scale(1.05) rotate(-1.4deg) translateY(-1px); filter: contrast(1.18) saturate(0.85) brightness(0.88); }
  .character-pose-seated .character-img   { transform: scale(1.01) translateY(2px); }
  .character-pose-rising .character-img   { transform: scale(1.05) translateY(-6px); }

  @keyframes portrait-float {
    0%, 100% { transform: translateY(0px); }
    50%      { transform: translateY(-6px); }
  }

  @keyframes halo-pulse {
    0%, 100% { opacity: 0.45; transform: scale(1); }
    50%      { opacity: 0.7;  transform: scale(1.06); }
  }

  @media (prefers-reduced-motion: reduce) {
    .character-portrait,
    .character-halo {
      animation: none;
    }
    .character-img {
      transition: none;
    }
  }
</style>
