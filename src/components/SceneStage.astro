---
/**
 * SceneStage — backdrop + characters + FX overlays rendered per scene.
 *
 * Server-renders ALL layers once; the ReaderShell client script swaps which
 * ones are visible via [data-active] / GSAP, so scene transitions are pure
 * CSS opacity + transform with no DOM churn.
 */
import Starfield from './Starfield.astro';
import CharacterSilhouette from './CharacterSilhouette.astro';

interface Props {
  bookSlug: string;
  characters: Array<{ id: string; silhouetteColor: string }>;
}

const { bookSlug, characters } = Astro.props;
const POSES = ['idle', 'tense', 'reaching', 'reeling', 'seated', 'rising'] as const;
---

<div
  class="scene-stage absolute inset-0 overflow-hidden"
  data-scene-stage
  data-backdrop="cosmos"
  data-fx="none"
>
  <!-- ===== BACKDROPS ===== -->
  <div class="absolute inset-0 transition-opacity duration-700 ease-out" data-backdrop-layer="cosmos">
    <Starfield density={140} tint="#050402" />
    <!-- ink-drop ripple, very slow -->
    <div class="absolute inset-0 pointer-events-none ink-drop"></div>
  </div>

  <!-- Studio City office -->
  <div
    class="absolute inset-0 transition-opacity duration-700 ease-out opacity-0"
    data-backdrop-layer="studio-city"
    style="background:
      radial-gradient(ellipse at 70% 30%, rgba(255,150,80,0.18), transparent 60%),
      radial-gradient(circle at 20% 80%, rgba(255,59,26,0.10), transparent 55%),
      linear-gradient(160deg, #1a1208 0%, #2a1d0c 60%, #0a0805 100%);"
  >
    <div
      class="absolute bottom-[18%] left-0 right-0 h-1.5 opacity-50 traffic-ribbon"
      style="background:
        repeating-linear-gradient(90deg, rgba(255,180,80,0.6) 0 4px, transparent 4px 18px),
        repeating-linear-gradient(90deg, rgba(255,80,60,0.45) 0 3px, transparent 3px 22px);
        filter: blur(1.5px);"
    ></div>
    <div class="absolute inset-0 pointer-events-none" style="box-shadow: inset 0 0 200px rgba(0,0,0,0.75);"></div>
  </div>

  <!-- Vernon scrap yard back office (Alex Ch.II) -->
  <div
    class="absolute inset-0 transition-opacity duration-700 ease-out opacity-0"
    data-backdrop-layer="vernon-yard"
    style="background:
      radial-gradient(ellipse at 80% 70%, rgba(80,130,200,0.18), transparent 60%),
      linear-gradient(170deg, #10130d 0%, #1b1a14 60%, #08090a 100%);"
  >
    <!-- corrugated steel verticals -->
    <div class="absolute inset-0 opacity-25"
         style="background: repeating-linear-gradient(90deg, rgba(255,255,255,0.04) 0 6px, transparent 6px 26px);"></div>
    <!-- TV flicker bottom-right -->
    <div class="absolute bottom-[20%] right-[12%] w-40 h-24 rounded-sm tv-flicker"
         style="background: radial-gradient(ellipse at center, rgba(140,200,255,0.45), rgba(40,60,90,0.2) 70%, transparent 100%);"></div>
    <div class="absolute inset-0 pointer-events-none" style="box-shadow: inset 0 0 200px rgba(0,0,0,0.75);"></div>
  </div>

  <!-- D.C. Lab (Kassidy Ch.III) -->
  <div
    class="absolute inset-0 transition-opacity duration-700 ease-out opacity-0"
    data-backdrop-layer="dc-lab"
    style="background:
      radial-gradient(ellipse at 50% 40%, rgba(60,120,200,0.20), transparent 60%),
      linear-gradient(180deg, #06080f 0%, #0a1018 60%, #04060a 100%);"
  >
    <!-- three monitor glows in an arc -->
    <div class="absolute top-[28%] left-[18%] w-44 h-28 rounded-sm monitor-glow"></div>
    <div class="absolute top-[22%] left-[42%] w-48 h-32 rounded-sm monitor-glow" style="animation-delay: -1.2s;"></div>
    <div class="absolute top-[28%] right-[18%] w-44 h-28 rounded-sm monitor-glow" style="animation-delay: -2.4s;"></div>
    <!-- grid floor lines -->
    <div class="absolute inset-x-0 bottom-0 h-1/3 opacity-30"
         style="background: linear-gradient(to top, rgba(120,180,255,0.15), transparent),
                repeating-linear-gradient(0deg, rgba(120,180,255,0.10) 0 1px, transparent 1px 24px),
                repeating-linear-gradient(90deg, rgba(120,180,255,0.10) 0 1px, transparent 1px 24px);
                mask-image: linear-gradient(to top, black, transparent);"></div>
  </div>

  <!-- Scottsdale workshop (Sam Ch.IV) -->
  <div
    class="absolute inset-0 transition-opacity duration-700 ease-out opacity-0"
    data-backdrop-layer="scottsdale-shop"
    style="background:
      radial-gradient(ellipse at 50% 60%, rgba(255,180,90,0.35), transparent 50%),
      radial-gradient(ellipse at 50% 60%, rgba(255,120,40,0.15), transparent 70%),
      linear-gradient(180deg, #0a0805 0%, #1c130a 60%, #050402 100%);"
  >
    <!-- focused lamp pool -->
    <div class="absolute left-1/2 top-[55%] -translate-x-1/2 w-[60%] h-[40%] rounded-full lamp-pool"
         style="background: radial-gradient(ellipse at center, rgba(255,210,140,0.45), transparent 70%);"></div>
    <!-- glints on tools -->
    <div class="absolute inset-0 pointer-events-none glints"></div>
  </div>

  <!-- Alex's kitchen / apartment (the table-talk scenes) -->
  <div
    class="absolute inset-0 transition-opacity duration-700 ease-out opacity-0"
    data-backdrop-layer="alex-kitchen"
    style="background:
      radial-gradient(ellipse at 50% 45%, rgba(255,170,90,0.18), transparent 65%),
      linear-gradient(180deg, #15110a 0%, #1f180e 60%, #08070a 100%);"
  >
    <!-- pendant lamp pool -->
    <div class="absolute left-1/2 top-[20%] -translate-x-1/2 w-[55%] h-[60%] rounded-full"
         style="background: radial-gradient(ellipse at center, rgba(255,210,140,0.22), transparent 70%);"></div>
    <div class="absolute inset-0 pointer-events-none" style="box-shadow: inset 0 0 220px rgba(0,0,0,0.8);"></div>
  </div>

  <!-- LA alley (mugging) -->
  <div
    class="absolute inset-0 transition-opacity duration-700 ease-out opacity-0"
    data-backdrop-layer="la-alley"
    style="background:
      radial-gradient(ellipse at 50% 0%, rgba(255,170,60,0.20), transparent 50%),
      linear-gradient(180deg, #0a0905 0%, #1a1208 50%, #050403 100%);"
  >
    <!-- brick wall verticals -->
    <div class="absolute inset-0 opacity-25"
         style="background: repeating-linear-gradient(90deg, rgba(120,80,60,0.20) 0 30px, transparent 30px 32px),
                          repeating-linear-gradient(0deg, rgba(120,80,60,0.15) 0 14px, transparent 14px 16px);"></div>
  </div>

  <!-- LA night freeway -->
  <div
    class="absolute inset-0 transition-opacity duration-700 ease-out opacity-0"
    data-backdrop-layer="la-freeway"
    style="background:
      linear-gradient(180deg, #06070d 0%, #0c0a14 50%, #1a0805 100%);"
  >
    <div class="absolute inset-x-0 bottom-[25%] h-2 freeway-tail-lights"></div>
    <div class="absolute inset-x-0 bottom-[35%] h-1.5 freeway-tail-lights" style="animation-direction: reverse; opacity: 0.55;"></div>
  </div>

  <!-- Warehouse fire -->
  <div
    class="absolute inset-0 transition-opacity duration-700 ease-out opacity-0"
    data-backdrop-layer="warehouse-fire"
    style="background:
      radial-gradient(ellipse at 50% 80%, rgba(255,120,30,0.55), transparent 60%),
      radial-gradient(ellipse at 50% 100%, rgba(255,60,10,0.35), transparent 70%),
      linear-gradient(180deg, #08060a 0%, #200a04 70%, #4a1804 100%);"
  >
    <div class="absolute inset-0 fire-flicker"></div>
    <div class="absolute inset-0 smoke-drift pointer-events-none"></div>
  </div>

  <!-- Ohio night highway -->
  <div
    class="absolute inset-0 transition-opacity duration-700 ease-out opacity-0"
    data-backdrop-layer="ohio-night"
    style="background:
      radial-gradient(ellipse at 50% 70%, rgba(120,150,200,0.18), transparent 60%),
      linear-gradient(180deg, #04060a 0%, #08101c 60%, #030506 100%);"
  >
    <div class="absolute left-1/2 top-[55%] -translate-x-1/2 w-[80%] h-[30%] headlight-cone"></div>
  </div>

  <!-- Dublin street -->
  <div
    class="absolute inset-0 transition-opacity duration-700 ease-out opacity-0"
    data-backdrop-layer="dublin-street"
    style="background:
      radial-gradient(ellipse at 50% 90%, rgba(255,200,80,0.22), transparent 55%),
      linear-gradient(180deg, #0a0a0c 0%, #14110e 60%, #050403 100%);"
  >
    <div class="absolute inset-0 opacity-30"
         style="background: repeating-linear-gradient(90deg, rgba(160,100,60,0.20) 0 60px, transparent 60px 64px);"></div>
  </div>

  <!-- Dark apartment -->
  <div
    class="absolute inset-0 transition-opacity duration-700 ease-out opacity-0"
    data-backdrop-layer="apartment-dark"
    style="background:
      radial-gradient(ellipse at 30% 30%, rgba(80,80,120,0.10), transparent 60%),
      linear-gradient(180deg, #050608 0%, #0b0a10 60%, #020203 100%);"
  ></div>

  <!-- Inglewood (legacy) -->
  <div
    class="absolute inset-0 transition-opacity duration-700 ease-out opacity-0"
    data-backdrop-layer="inglewood"
    style="background:
      radial-gradient(ellipse at 50% 50%, rgba(60,120,80,0.22), transparent 70%),
      linear-gradient(180deg, #08110a 0%, #0a0805 100%);"
  >
    <div class="absolute inset-0 animate-flicker" style="background: radial-gradient(ellipse at 50% 45%, rgba(120,220,160,0.10), transparent 50%);"></div>
  </div>

  <!-- Void -->
  <div class="absolute inset-0 transition-opacity duration-700 ease-out opacity-0" data-backdrop-layer="void" style="background: #000;"></div>

  <!-- Flash red -->
  <div
    class="absolute inset-0 transition-opacity duration-200 ease-in opacity-0"
    data-backdrop-layer="flash-red"
    style="background: radial-gradient(ellipse at 50% 50%, #ff3b1a 0%, #8a0a00 60%, #000 100%);"
  ></div>

  <!-- Sunset window -->
  <div
    class="absolute inset-0 transition-opacity duration-700 ease-out opacity-0"
    data-backdrop-layer="sunset-window"
    style="background: linear-gradient(180deg, #2a1808 0%, #50220a 40%, #aa3a14 70%, #1a0a04 100%);"
  >
    <div class="absolute bottom-[15%] left-0 right-0 h-2 opacity-60 traffic-ribbon"
         style="background: repeating-linear-gradient(90deg, rgba(255,180,80,0.7) 0 4px, transparent 4px 20px); filter: blur(1px);"></div>
  </div>

  <!-- Blank fallback -->
  <div class="absolute inset-0 transition-opacity duration-700 ease-out opacity-0" data-backdrop-layer="blank" style="background: #0a0805;"></div>

  <!-- ===== FX OVERLAYS ===== -->

  <!-- red-streak: horizontal lightning sweep -->
  <div class="absolute inset-0 pointer-events-none opacity-0" data-fx-layer="red-streak">
    <div class="absolute top-1/2 left-0 right-0 -translate-y-1/2 h-2"
         style="background: linear-gradient(90deg, transparent 0%, #ff3b1a 40%, #ffffff 50%, #ff3b1a 60%, transparent 100%);
                box-shadow: 0 0 40px 10px rgba(255,59,26,0.9);"
         data-streak-bar></div>
    <!-- secondary forked bolt -->
    <div class="absolute top-[42%] left-[20%] right-[20%] h-px"
         style="background: linear-gradient(90deg, transparent, #ff8060, white, #ff8060, transparent);
                box-shadow: 0 0 20px 4px rgba(255,120,80,0.8);
                transform: rotate(-3deg);"
         data-streak-bolt></div>
  </div>

  <!-- flash: full white pop -->
  <div class="absolute inset-0 pointer-events-none opacity-0 bg-white" data-fx-layer="flash"></div>

  <!-- book-float: floating book -->
  <div class="absolute inset-0 pointer-events-none opacity-0 flex items-center justify-center" data-fx-layer="book-float">
    <div class="w-24 h-32 rounded-r-sm shadow-[0_30px_60px_-10px_rgba(255,59,26,0.6)]"
         style="background: linear-gradient(135deg, #0a0805, #3d321e);
                border-left: 4px solid #ff3b1a;
                transform: rotate(-6deg);"
         data-float-book></div>
  </div>

  <!-- time-pinch: slow-mo blur veil -->
  <div class="absolute inset-0 pointer-events-none opacity-0"
       data-fx-layer="time-pinch"
       style="backdrop-filter: blur(2px); background: radial-gradient(ellipse at center, rgba(0,0,0,0) 30%, rgba(0,0,0,0.5) 100%);"></div>

  <!-- tilt-world vignette -->
  <div class="absolute inset-0 pointer-events-none opacity-0"
       data-fx-layer="tilt-world"
       style="box-shadow: inset 0 0 300px rgba(0,0,0,0.8);"></div>

  <!-- glass-slide: glass sliding across the table -->
  <div class="absolute inset-0 pointer-events-none opacity-0 flex items-end justify-center pb-[28%]" data-fx-layer="glass-slide">
    <div class="w-12 h-16 rounded-sm border border-white/30"
         style="background: linear-gradient(180deg, rgba(255,255,255,0.18), rgba(255,255,255,0.05));
                box-shadow: 0 0 20px rgba(255,255,255,0.25);"
         data-slide-glass></div>
  </div>

  <!-- metal-reshape: shimmering metallic ripple -->
  <div class="absolute inset-0 pointer-events-none opacity-0 flex items-center justify-center" data-fx-layer="metal-reshape">
    <div class="w-40 h-40 rounded-full"
         style="background: conic-gradient(from 0deg, #c0a070, #fff5d8, #c0a070, #8a6a40, #c0a070);
                filter: blur(2px);
                mix-blend-mode: screen;
                opacity: 0.85;"
         data-metal-disc></div>
  </div>

  <!-- energy-transfer: arc between two points -->
  <div class="absolute inset-0 pointer-events-none opacity-0" data-fx-layer="energy-transfer">
    <div class="absolute top-1/2 left-[22%] w-[56%] h-1 -translate-y-1/2"
         style="background: linear-gradient(90deg, transparent, #6cf, white, #6cf, transparent);
                box-shadow: 0 0 24px 6px rgba(120,200,255,0.7);"
         data-energy-arc></div>
  </div>

  <!-- ant-trail: small dot crossing the screen -->
  <div class="absolute inset-0 pointer-events-none opacity-0" data-fx-layer="ant-trail">
    <div class="absolute top-[78%] left-0 w-2 h-2 rounded-full bg-amber-300/90"
         style="box-shadow: 0 0 6px rgba(255,200,100,0.9);"
         data-ant-dot></div>
  </div>

  <!-- data-stream: vertical cascading characters -->
  <div class="absolute inset-0 pointer-events-none opacity-0 overflow-hidden" data-fx-layer="data-stream">
    {Array.from({ length: 8 }).map((_, i) => (
      <div
        class="absolute top-0 text-[10px] font-mono leading-tight text-cyan-300/60 data-column"
        style={`left: ${10 + i * 11}%; animation-delay: ${(i * 0.25).toFixed(2)}s;`}
      >01010<br/>11001<br/>00110<br/>10101<br/>11100<br/>01011<br/>00010</div>
    ))}
  </div>

  <!-- truck-stop: skid spark -->
  <div class="absolute inset-0 pointer-events-none opacity-0" data-fx-layer="truck-stop">
    <div class="absolute top-[68%] left-0 right-0 h-0.5"
         style="background: linear-gradient(90deg, transparent 0%, rgba(255,200,80,0.0) 40%, rgba(255,180,40,0.95) 60%, rgba(255,255,200,1) 75%, transparent 90%);
                box-shadow: 0 0 30px 6px rgba(255,180,40,0.7);"
         data-skid-bar></div>
  </div>

  <!-- map-pulse: world map with pulsing red dots -->
  <div class="absolute inset-0 pointer-events-none opacity-0 flex items-center justify-center" data-fx-layer="map-pulse">
    <div class="relative w-[70%] h-[55%] rounded-md border border-cyan-400/20"
         style="background:
           radial-gradient(circle at 24% 38%, rgba(80,160,220,0.10) 0 6%, transparent 7%),
           radial-gradient(circle at 30% 45%, rgba(80,160,220,0.10) 0 8%, transparent 9%),
           radial-gradient(circle at 56% 42%, rgba(80,160,220,0.10) 0 10%, transparent 11%),
           radial-gradient(circle at 75% 55%, rgba(80,160,220,0.10) 0 7%, transparent 8%),
           linear-gradient(180deg, rgba(10,20,40,0.6), rgba(4,8,16,0.85));">
      <span class="map-dot" style="left: 22%; top: 38%;"></span>
      <span class="map-dot" style="left: 26%; top: 32%; animation-delay: 0.4s;"></span>
      <span class="map-dot" style="left: 48%; top: 35%; animation-delay: 0.8s;"></span>
      <span class="map-dot" style="left: 52%; top: 30%; animation-delay: 1.1s;"></span>
      <span class="map-dot" style="left: 60%; top: 28%; animation-delay: 1.4s;"></span>
      <span class="map-dot" style="left: 18%; top: 52%; animation-delay: 1.7s;"></span>
    </div>
  </div>

  <!-- ===== CHARACTERS ===== -->
  <div class="absolute inset-0 pointer-events-none">
    {characters.map(c => (
      <div class="absolute inset-0 transition-opacity duration-500 opacity-0" data-character-layer={c.id}>
        <div class="absolute bottom-0 transition-all duration-700 ease-out"
             data-character-slot={c.id}
             style="left: 50%; transform: translateX(-50%);">
          {POSES.map(p => (
            <div class="absolute bottom-0 left-1/2 -translate-x-1/2 opacity-0 transition-opacity duration-300"
                 data-character-pose={p}>
              <CharacterSilhouette
                id={`${bookSlug}-${c.id}-${p}`}
                pose={p}
                color={c.silhouetteColor}
                size="lg"
              />
            </div>
          ))}
        </div>
      </div>
    ))}
  </div>

  <!-- Bottom vignette so text stays readable -->
  <div class="absolute inset-x-0 bottom-0 h-1/2 pointer-events-none"
       style="background: linear-gradient(180deg, transparent 0%, rgba(5,4,2,0.7) 60%, rgba(5,4,2,0.95) 100%);"></div>
</div>

<style>
  /* Character positions */
  [data-character-slot][data-position="left"]   { left: 22%; transform: translateX(-50%); }
  [data-character-slot][data-position="center"] { left: 50%; transform: translateX(-50%); }
  [data-character-slot][data-position="right"]  { left: 78%; transform: translateX(-50%); }
  [data-character-slot][data-position="offscreen"] { left: 50%; transform: translateX(-50%) translateY(60%); opacity: 0; }

  /* Activation */
  [data-backdrop-layer][data-active="true"] { opacity: 1; }
  [data-character-layer][data-active="true"] { opacity: 1; }
  [data-character-pose][data-active="true"] { opacity: 1; position: relative; }

  /* Ambient animations */
  .ink-drop {
    background: radial-gradient(circle at 50% 60%, rgba(255,59,26,0.18), transparent 30%);
    filter: blur(40px);
    animation: ink-bloom 18s ease-in-out infinite;
  }
  @keyframes ink-bloom {
    0%, 100% { opacity: 0.0; transform: scale(0.7); }
    50%      { opacity: 0.5; transform: scale(1.4); }
  }

  .traffic-ribbon {
    background-size: 200% 100%;
    animation: traffic-scroll 12s linear infinite;
  }
  @keyframes traffic-scroll {
    from { background-position: 0 0; }
    to   { background-position: -400px 0; }
  }

  .tv-flicker {
    animation: tv-flicker 0.6s steps(2, end) infinite;
    filter: blur(3px);
  }
  @keyframes tv-flicker {
    0%, 100% { opacity: 0.9; }
    35%      { opacity: 0.4; }
    70%      { opacity: 1.0; }
  }

  .monitor-glow {
    background: linear-gradient(180deg, rgba(120,180,255,0.45), rgba(40,80,140,0.2));
    box-shadow: 0 0 50px rgba(80,140,220,0.45);
    animation: monitor-pulse 3s ease-in-out infinite;
    filter: blur(2px);
  }
  @keyframes monitor-pulse {
    0%, 100% { opacity: 0.55; }
    50%      { opacity: 0.95; }
  }

  .lamp-pool {
    filter: blur(8px);
    animation: lamp-breathe 5s ease-in-out infinite;
  }
  @keyframes lamp-breathe {
    0%, 100% { opacity: 0.85; transform: translateX(-50%) scale(1); }
    50%      { opacity: 1.0;  transform: translateX(-50%) scale(1.04); }
  }

  .glints {
    background: radial-gradient(circle at 30% 65%, rgba(255,240,200,0.15), transparent 1%),
                radial-gradient(circle at 62% 70%, rgba(255,240,200,0.18), transparent 1%),
                radial-gradient(circle at 48% 58%, rgba(255,240,200,0.2),  transparent 1%);
    animation: glint-twinkle 3s ease-in-out infinite alternate;
  }
  @keyframes glint-twinkle {
    from { opacity: 0.4; }
    to   { opacity: 1.0; }
  }

  .freeway-tail-lights {
    background: repeating-linear-gradient(90deg, rgba(255,80,40,0.85) 0 6px, transparent 6px 26px);
    filter: blur(1.5px);
    animation: tail-lights-flow 5s linear infinite;
  }
  @keyframes tail-lights-flow {
    from { background-position: 0 0; }
    to   { background-position: -260px 0; }
  }

  .fire-flicker {
    background: radial-gradient(ellipse at 50% 90%, rgba(255,160,40,0.7), transparent 60%);
    mix-blend-mode: screen;
    animation: fire-pulse 0.4s ease-in-out infinite alternate;
  }
  @keyframes fire-pulse {
    from { opacity: 0.55; transform: scale(0.95); }
    to   { opacity: 0.95; transform: scale(1.05); }
  }

  .smoke-drift {
    background: radial-gradient(ellipse at 30% 30%, rgba(200,200,200,0.10), transparent 50%),
                radial-gradient(ellipse at 70% 40%, rgba(180,180,180,0.10), transparent 55%);
    animation: smoke-shift 12s ease-in-out infinite alternate;
  }
  @keyframes smoke-shift {
    from { transform: translateX(-3%) translateY(0); opacity: 0.45; }
    to   { transform: translateX(3%) translateY(-2%); opacity: 0.75; }
  }

  .headlight-cone {
    background: radial-gradient(ellipse at 50% 100%, rgba(240,240,255,0.45), rgba(240,240,255,0.05) 60%, transparent 80%);
    filter: blur(8px);
    animation: headlight-sway 8s ease-in-out infinite alternate;
  }
  @keyframes headlight-sway {
    from { transform: translateX(-50%) rotate(-1deg); }
    to   { transform: translateX(-50%) rotate(1deg); }
  }

  .animate-flicker {
    animation: tv-flicker 0.5s steps(2, end) infinite;
  }

  /* FX-specific keyframes used by GSAP fallbacks */
  .data-column {
    animation: data-cascade 6s linear infinite;
  }
  @keyframes data-cascade {
    from { transform: translateY(-30%); opacity: 0.2; }
    50%  { opacity: 0.8; }
    to   { transform: translateY(120%); opacity: 0.0; }
  }

  .map-dot {
    position: absolute;
    width: 12px; height: 12px;
    border-radius: 9999px;
    background: #ff3b1a;
    box-shadow: 0 0 16px 4px rgba(255,59,26,0.7);
    transform: translate(-50%, -50%);
    animation: map-ping 2.4s ease-out infinite;
  }
  @keyframes map-ping {
    0%   { transform: translate(-50%, -50%) scale(0.6); opacity: 1; }
    70%  { transform: translate(-50%, -50%) scale(2.2); opacity: 0; }
    100% { opacity: 0; }
  }

  @media (prefers-reduced-motion: reduce) {
    .ink-drop, .traffic-ribbon, .tv-flicker, .monitor-glow, .lamp-pool, .glints,
    .freeway-tail-lights, .fire-flicker, .smoke-drift, .headlight-cone,
    .animate-flicker, .data-column, .map-dot {
      animation: none !important;
    }
  }
</style>
